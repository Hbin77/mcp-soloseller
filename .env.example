# === 서버 설정 ===
ALLOWED_ORIGINS=https://soloseller.cloud

# === 이메일 인증 (SMTP) ===
# Gmail 앱 비밀번호 발급: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# === Cloudflare Turnstile ===
# https://dash.cloudflare.com → Turnstile에서 사이트 키 발급
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# === 쿠팡 WING API ===
# wing.coupang.com → 판매자정보 → OPEN API 키 발급
COUPANG_VENDOR_ID=
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=

# === CJ대한통운 DX API ===
# 비워두면 테스트 모드 (가짜 송장 발급)
CJ_CUSTOMER_ID=
CJ_BIZ_REG_NUM=
# CJ DX API 게이트웨이 키 (기본값 사용 가능, 필요시 오버라이드)
CJ_GATEWAY_KEY_TEST=
CJ_GATEWAY_KEY_PROD=

# === 발송인 정보 ===
SENDER_NAME=
SENDER_PHONE=
SENDER_ZIPCODE=
SENDER_ADDRESS=
